{
  "private": true,
  "name": "specify-text-monorepo",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "pnpm -r build",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "test": "vitest run",
    "build:parser": "pnpm --filter @specify-text/parser build",
    "cz": "git add . && git cz"
  },
  "devDependencies": {
    "@rollup/plugin-typescript": "^12.3.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20.10.5",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@typescript-eslint/eslint-plugin": "^6.14.0",
    "@typescript-eslint/parser": "^6.14.0",
    "@vitejs/plugin-react": "^6.0.2",
    "classnames": "^2.3.2",
    "commitizen": "^4.3.0",
    "cz-conventional-changelog": "^3.3.0",
    "eslint": "^8.55.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "jsdom": "^29.1.1",
    "react": "^18",
    "react-dom": "^18",
    "sass": "^1.69.5",
    "tslib": "^2.6.2",
    "tsx": "^4.22.2",
    "typescript": "^5.2.2",
    "vite": "^8.0.13",
    "vitest": "^4.1.6",
    "@specify-text/core": "workspace:*",
    "@specify-text/parser": "workspace:*",
    "@specify-text/react": "workspace:*",
    "@specify-text/react-widgets-base": "workspace:*",
    "@specify-text/react-widgets-builtin": "workspace:*",
    "specify-text": "workspace:*"
  }
}